generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String         @id @default(cuid())
  email         String?        @unique
  name          String?
  image         String?
  isGuest       Boolean        @default(true)
  createdAt     DateTime       @default(now())
  conversations Conversation[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  title     String    @default("New conversation")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant"
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  // A user message carries a scan; an assistant message carries an analysis.
  scan     PromptScan?
  analysis Analysis?

  @@index([conversationId, createdAt])
}

model PromptScan {
  id             String  @id @default(cuid())
  messageId      String  @unique
  riskLevel      String // Severity
  injectionScore Float
  blocked        Boolean @default(false)
  /// Finding[] — denormalized; findings are never queried independently.
  findings       Json
  message        Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Analysis {
  id                 String   @id @default(cuid())
  messageId          String   @unique
  trustScore         Int
  band               String // TrustBand
  hallucinationRisk  Float
  privacyRisk        Float
  injectionRisk      Float
  verificationScore  Float? // null when the response had no factual claims
  summary            String   @db.Text
  durationMs         Int
  createdAt          DateTime @default(now())
  message            Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  claims             Claim[]
}

model Claim {
  id         String     @id @default(cuid())
  analysisId String
  text       String     @db.Text
  verdict    String // Verdict
  confidence Float
  reasoning  String     @db.Text
  isSpecific Boolean    @default(false)
  analysis   Analysis   @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  evidence   Evidence[]

  @@index([analysisId])
}

model Evidence {
  id        String @id @default(cuid())
  claimId   String
  url       String
  title     String
  snippet   String @db.Text
  stance    String // "supports" | "contradicts" | "neutral"
  relevance Float
  claim     Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([claimId])
}
